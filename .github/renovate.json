{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:daily"
  ],
  "enabledManagers": [
    "gomod",
    "github-actions"
  ],
  "timezone": "Asia/Tokyo",
  "prConcurrentLimit": 10,
  "packageRules": [
    {
      "description": "Keep Go module artifacts tidy before opening dependency PRs.",
      "matchManagers": [
        "gomod"
      ],
      "postUpdateOptions": [
        "gomodTidy"
      ]
    },
    {
      "description": "Keep indirect Go module updates in scope.",
      "matchManagers": [
        "gomod"
      ],
      "matchDepTypes": [
        "indirect"
      ],
      "enabled": true
    }
  ]
}
